# =============================================================================
# Stora Backend Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---- Server ----
PORT=9421
HOST=0.0.0.0
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
DEBUG=false
TIME_ZONE=Asia/Shanghai
TITLE=Stora
DOMAIN=http://localhost:9421

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=stora

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT ----
JWT_EXPIRATION_DELTA=7200        # Access token TTL (seconds, default 2h)
REFRESH_TOKEN_EXPIRATION_DELTA=64800  # Refresh token TTL (seconds, default 18h)

# ---- Storage ----
STORAGE_DRIVER=local             # local or s3
STORAGE_OBJECTS_DIR=storage/objects  # Content-addressed objects root (git-style)
TEMP_FOLDER=temp/upload          # Temp directory for chunked upload assembly

# ---- S3 / MinIO (only if STORAGE_DRIVER=s3) ----
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=stora
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ---- Email / SMTP (for notifications & verification codes) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@stora.local

# ---- Vault / Encryption ----
# Vault 加密密钥（AES-256-GCM）。留空则使用 SECRET_KEY 派生。
# 建议设置独立的密钥，避免 SECRET_KEY 泄露影响 Vault 数据安全。
VAULT_ENCRYPTION_KEY=
