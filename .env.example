# ============================================================================
# Stora 环境变量配置文件
# 复制此文件为 .env 并根据实际情况修改
# ============================================================================
# cp .env.example .env

# ============================================================================
# 基础配置
# ============================================================================
DOMAIN=http://localhost:9421
DEBUG=False
ENVIRONMENT=development
TIME_ZONE=Asia/Shanghai
TITLE=Stora
SECRET_KEY=change-this-to-a-random-secret-key
ENCRYPTION_KEY=change-this-to-32-char-hex-key

# ============================================================================
# 数据库 (PostgreSQL)
# ============================================================================
DB_ENGINE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=stora
DB_TABLE_PREFIX=
# 连接池配置
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=20
DB_POOL_TIMEOUT=30
# 打印 SQL 日志（调试用）
DATABASE_ECHO=False

# ============================================================================
# Redis 缓存
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================================
# JWT 认证
# ============================================================================
JWT_EXPIRATION_DELTA=3600           # Access Token 过期时间（秒）
REFRESH_TOKEN_EXPIRATION_DELTA=2592000  # Refresh Token 过期时间（秒，默认30天）

# ============================================================================
# OAuth 第三方登录 (可选)
# ============================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:9421/api/v2/auth/oauth/callback

# ============================================================================
# 邮件服务 (SMTP) + 验证码登录
# ============================================================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_DEFAULT_SENDER=your-email@gmail.com

# ============================================================================
# S3 对象存储 (可选，默认使用本地文件存储)
# ============================================================================
S3_ENABLED=False
S3_ENDPOINT_URL=http://localhost:9000   # MinIO 端点，AWS S3 可不设置
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=stora
S3_REGION=us-east-1
S3_USE_SSL=False
S3_SIGNATURE_VERSION=s3v4

# ============================================================================
# 搜索 (Meilisearch，可选)
# ============================================================================
MEILI_HTTP_ADDR=http://localhost:7700
MEILI_MASTER_KEY=master-key

# ============================================================================
# Sentry 错误追踪 (可选)
# ============================================================================
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

# ============================================================================
# 微信支付 (可选，用于存储套餐购买)
# ============================================================================
WECHAT_APPID=
WECHAT_MCHID=
WECHAT_API_V3_KEY=
WECHAT_PRIVATE_KEY=
WECHAT_CERT_SERIAL_NO=
WECHAT_CERT_DIR=./cert
WECHAT_NOTIFY_URL=https://yourdomain.com/api/payment/wechat/notify

# ============================================================================
# 支付宝支付 (可选)
# ============================================================================
ALIPAY_APPID=
ALIPAY_DEBUG=True
ALIPAY_RETURN_URL=http://localhost:9421/api/payment/alipay/return
ALIPAY_NOTIFY_URL=http://localhost:9421/api/payment/alipay/notify
ALIPAY_PRIVATE_KEY=

# ============================================================================
# 站点信息
# ============================================================================
BEIAN=京ICP备12345678号

# ============================================================================
# 服务端口 (开发环境)
# ============================================================================
# 后端 FastAPI 端口
HOST=0.0.0.0
PORT=9421
